# ─── GRC Platform Environment Configuration ─────────────────────────────────
# Copy this file to .env and fill in real values before running

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=grcdb
POSTGRES_USER=grcuser
POSTGRES_PASSWORD=Change_Me_Strong_Password_123!

# ─── Application ─────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string-in-production

DEBUG=false

# ─── pgAdmin (optional) ──────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@yourdomain.com
PGADMIN_PASSWORD=Change_Me_pgAdmin_Password!
